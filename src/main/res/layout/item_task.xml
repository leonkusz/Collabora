<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="wrap_content"

    android:layout_marginHorizontal="24dp"
    android:layout_marginBottom="12dp"

    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="20dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:orientation="horizontal">

        <!-- PRIORITY BAR -->
        <View
            android:id="@+id/viewPriority"
            android:layout_width="5dp"
            android:layout_height="match_parent"
            android:background="#1E9E75"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:orientation="vertical"
            android:padding="16dp">

            <!-- TITLE -->
            <TextView
                android:id="@+id/tvTaskTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

                android:text="Judul Tugas"
                android:textColor="#1F2E28"
                android:textSize="15sp"
                android:textStyle="bold"

                android:maxLines="2"
                android:ellipsize="end"

                android:fontFamily="sans-serif-medium"
                android:lineSpacingExtra="2dp"/>

            <!-- DESCRIPTION -->
            <TextView
                android:id="@+id/tvTaskDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

                android:layout_marginTop="8dp"

                android:text="Deskripsi tugas akan muncul di sini."
                android:textColor="#6B9480"
                android:textSize="13sp"

                android:maxLines="2"
                android:ellipsize="end"/>

            <!-- STATUS + PRIORITY -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <!-- STATUS -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"

                    android:layout_marginEnd="8dp"

                    app:cardBackgroundColor="#E6F7F2"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp">

                    <TextView
                        android:id="@+id/tvTaskStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"

                        android:gravity="center"
                        android:paddingHorizontal="12dp"

                        android:text="Proses"
                        android:textColor="#0F6E56"
                        android:textSize="11sp"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <!-- PRIORITY -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardPriority"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"

                    app:cardBackgroundColor="#FEE2E2"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp">

                    <TextView
                        android:id="@+id/tvTaskPriority"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"

                        android:gravity="center"
                        android:paddingHorizontal="12dp"

                        android:text="Tinggi"
                        android:textColor="#991B1B"
                        android:textSize="11sp"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- DEADLINE -->
            <TextView
                android:id="@+id/tvTaskDeadline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

                android:layout_marginTop="14dp"

                android:text="⏰ Deadline"
                android:textColor="#EF4444"
                android:textSize="12sp"
                android:textStyle="bold"

                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>