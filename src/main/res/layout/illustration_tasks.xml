<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_status_solid" android:backgroundTint="#FF4081" android:text="RA" android:textColor="#FFFFFF" android:gravity="center" android:textStyle="bold" android:layout_marginEnd="8dp"/>
        <TextView android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_status_solid" android:backgroundTint="#7C4DFF" android:text="DS" android:textColor="#FFFFFF" android:gravity="center" android:textStyle="bold" android:layout_marginEnd="8dp"/>
        <TextView android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_status_solid" android:backgroundTint="#FF5252" android:text="NK" android:textColor="#FFFFFF" android:gravity="center" android:textStyle="bold" android:layout_marginEnd="8dp"/>
        <TextView android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_status_solid" android:backgroundTint="#00E676" android:text="FP" android:textColor="#FFFFFF" android:gravity="center" android:textStyle="bold"/>
    </LinearLayout>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="UI/UX RESEARCH · 72%" android:textColor="#BDBDBD" android:textSize="12sp" android:layout_marginTop="16dp" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="20dp">
        <TextView android:layout_width="20dp" android:layout_height="20dp" android:background="@drawable/bg_collabora_outline" android:text="✓" android:textColor="#1e9e75" android:gravity="center" android:textStyle="bold" android:layout_marginEnd="12dp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Setup Firebase Database" android:textColor="#1A1A1A" android:textSize="14sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_status_solid" android:text="Done" android:textColor="#757575" android:textSize="11sp" android:paddingHorizontal="10dp" android:paddingVertical="4dp" android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="16dp">
        <View android:layout_width="20dp" android:layout_height="20dp" android:background="@drawable/bg_collabora_outline" android:layout_marginEnd="12dp" android:backgroundTint="#BDBDBD"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Buat wireframe login" android:textColor="#1A1A1A" android:textSize="14sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_collabora_outline" android:text="Progres" android:textColor="#1e9e75" android:textSize="11sp" android:paddingHorizontal="10dp" android:paddingVertical="4dp" android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="16dp">
        <View android:layout_width="20dp" android:layout_height="20dp" android:background="@drawable/bg_collabora_outline" android:layout_marginEnd="12dp" android:backgroundTint="#BDBDBD"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Analisis kompetitor" android:textColor="#1A1A1A" android:textSize="14sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_status_solid" android:text="Pending" android:textColor="#757575" android:textSize="11sp" android:paddingHorizontal="10dp" android:paddingVertical="4dp" android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>