<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"

        android:fillViewport="true"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:scrollbars="none"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- ICON -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📩"
            android:textSize="72sp"/>

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Verifikasi Email"
            android:textColor="#1F1F1F"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <!-- SUBTITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:text="Kami telah mengirim link verifikasi ke email kamu. Silakan cek Gmail lalu klik link verifikasi."
            android:textAlignment="center"
            android:textColor="#777777"
            android:textSize="16sp"
            android:lineSpacingExtra="4dp"/>

        <!-- BUTTON OPEN GMAIL -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenGmail"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="42dp"
            android:text="Buka Gmail"
            android:textAllCaps="false"
            android:textSize="17sp"
            app:backgroundTint="#1E9E75"
            app:cornerRadius="16dp"/>

        <!-- BUTTON VERIFIED -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAlreadyVerified"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="16dp"
            android:text="Saya Sudah Verifikasi"
            android:textAllCaps="false"
            android:textColor="#1E9E75"
            android:textSize="17sp"
            app:backgroundTint="#E8F5F0"
            app:cornerRadius="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnResendEmail"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="16dp"
            android:text="Kirim Ulang Verifikasi"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            app:backgroundTint="#1E9E75"
            app:cornerRadius="16dp"/>

    </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>