<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F2"
    android:fitsSystemWindows="true">

    <!-- TOP BAR -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="12dp"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- PROFILE -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardProfileTop"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#CDE8DF">

            <TextView
                android:id="@+id/tvProfileInitial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="RA"
                android:textColor="#0F6E56"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"/>

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivProfilePhoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"/>
        </androidx.cardview.widget.CardView>

        <!-- NAME -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tvGreetingName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Halo, User 👋"
                android:textColor="#1F2E28"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selamat datang di Collabora"
                android:textColor="#6B9480"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- EMPTY STATE -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:fillViewport="true"
        android:scrollbars="none"
        android:paddingBottom="120dp"

        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/cardBottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/layoutEmptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="32dp"
            android:paddingTop="40dp"
            android:paddingBottom="40dp">

            <!-- ICON -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👥"
                android:textSize="90sp"/>

            <!-- TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"

                android:text="Belum Punya Tim"
                android:textColor="#1F2E28"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:fontFamily="sans-serif-black"/>

            <!-- SUBTITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:layout_marginTop="14dp"
                android:gravity="center"

                android:text="Mulai kolaborasi dengan membuat tim baru atau gabung menggunakan kode undangan."
                android:textAlignment="center"
                android:textColor="#6B9480"
                android:textSize="16sp"
                android:lineSpacingExtra="4dp"
                android:fontFamily="sans-serif-medium"/>

            <!-- CREATE TEAM BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreateTeam"
                android:layout_width="match_parent"
                android:layout_height="60dp"

                android:layout_marginTop="40dp"

                android:text="Buat Tim"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"

                app:backgroundTint="#1E9E75"
                app:cornerRadius="18dp"/>

            <!-- JOIN TEAM BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnJoinTeam"
                android:layout_width="match_parent"
                android:layout_height="60dp"

                android:layout_marginTop="14dp"

                android:text="Gabung Tim"
                android:textAllCaps="false"
                android:textColor="#1E9E75"
                android:textSize="17sp"
                android:textStyle="bold"

                app:backgroundTint="#DDF3EC"
                app:cornerRadius="18dp"/>

        </LinearLayout>

    </ScrollView>

    <!-- BOTTOM NAVIGATION -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardBottomNav"
        android:layout_width="match_parent"
        android:layout_height="78dp"

        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="24dp"

        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="36dp"
        app:cardElevation="12dp"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"

            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="5">

            <!-- HOME -->
            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"

                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏠"
                    android:textSize="20sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    android:text="Beranda"
                    android:textColor="#1E9E75"
                    android:textSize="10sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- CALENDAR -->
            <LinearLayout
                android:id="@+id/navCalendar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"

                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅"
                    android:textSize="20sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    android:text="Kalender"
                    android:textColor="#9AB8AE"
                    android:textSize="10sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- ADD -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center">

                <androidx.cardview.widget.CardView
                    android:id="@+id/btnAddTask"
                    android:layout_width="54dp"
                    android:layout_height="54dp"

                    app:cardBackgroundColor="#1E9E75"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="6dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"

                        android:gravity="center"
                        android:text="+"
                        android:textColor="#FFFFFF"
                        android:textSize="30sp"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- TEAM -->
            <LinearLayout
                android:id="@+id/navTeam"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"

                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👥"
                    android:textSize="20sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    android:text="Tim"
                    android:textColor="#9AB8AE"
                    android:textSize="10sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- PROFILE -->
            <LinearLayout
                android:id="@+id/navProfile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"

                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤"
                    android:textSize="20sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    android:text="Profil"
                    android:textColor="#9AB8AE"
                    android:textSize="10sp"
                    android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>